{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["image"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository (e.g., ghcr.io/pleme-io/releases)"
        },
        "tag": {
          "type": "string",
          "default": "latest"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "Always"
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 0,
      "default": 1
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "containerPort"],
        "properties": {
          "name": { "type": "string" },
          "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "protocol": { "type": "string", "enum": ["TCP", "UDP"] }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "port", "targetPort"],
            "properties": {
              "name": { "type": "string" },
              "port": { "type": "integer" },
              "targetPort": { "type": ["string", "integer"] },
              "protocol": { "type": "string" }
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "default": "/healthz" },
        "readyPath": { "type": "string", "default": "/readyz" },
        "port": { "type": ["string", "integer"], "default": "http" }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "port": { "type": ["string", "integer"] },
        "path": { "type": "string" },
        "interval": { "type": "string" },
        "scrapeTimeout": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "allowPrometheus": { "type": "boolean", "default": true },
        "allowDns": { "type": "boolean", "default": true }
      }
    },
    "env": { "type": "array" },
    "envFrom": { "type": "array" },
    "volumeMounts": { "type": "array" },
    "volumes": { "type": "array" }
  }
}
