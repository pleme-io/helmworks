{
  "uid": "headscale-overview",
  "title": "Headscale Overview",
  "description": "Self-hosted Tailscale coordination server — health, resources, network, and logs",
  "tags": ["headscale", "tailscale", "vpn", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up{job=~\".*headscale.*\"}, namespace)",
        "refresh": 2,
        "includeAll": false,
        "current": { "text": "headscale", "value": "headscale" }
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up{namespace=\"$namespace\", job=~\".*headscale.*\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Service Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "none", "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 3,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      },
      "options": { "graphMode": "none", "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 4,
      "title": "Pod Restarts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"$namespace\", pod=~\"headscale.*\"})",
          "legendFormat": "Restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 5,
      "title": "Container Ready",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kube_pod_container_status_ready{namespace=\"$namespace\", pod=~\"headscale.*\"}",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NOT READY", "color": "red" }, "1": { "text": "READY", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "none", "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 10,
      "title": "Resource Usage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\"}[5m])",
          "legendFormat": "Usage"
        },
        {
          "expr": "kube_pod_container_resource_requests{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\", resource=\"cpu\"}",
          "legendFormat": "Request"
        },
        {
          "expr": "kube_pod_container_resource_limits{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\", resource=\"cpu\"}",
          "legendFormat": "Limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Request" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "custom.fillOpacity", "value": 0 }] },
          { "matcher": { "id": "byName", "options": "Limit" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "custom.fillOpacity", "value": 0 }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\"}",
          "legendFormat": "Working Set"
        },
        {
          "expr": "container_memory_rss{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "kube_pod_container_resource_requests{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\", resource=\"memory\"}",
          "legendFormat": "Request"
        },
        {
          "expr": "kube_pod_container_resource_limits{namespace=\"$namespace\", pod=~\"headscale.*\", container=\"headscale\", resource=\"memory\"}",
          "legendFormat": "Limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Request" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "custom.fillOpacity", "value": 0 }] },
          { "matcher": { "id": "byName", "options": "Limit" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "custom.fillOpacity", "value": 0 }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 20,
      "title": "Go Runtime",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "go_goroutines{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 22,
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{namespace=\"$namespace\", job=~\".*headscale.*\"}[5m])",
          "legendFormat": "GC time/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 23,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_open_fds{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "Open FDs"
        },
        {
          "expr": "process_max_fds{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "Max FDs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Max FDs" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "custom.fillOpacity", "value": 0 }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 30,
      "title": "Go Memory Internals",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Go Heap",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "Heap Alloc"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "Heap In-Use"
        },
        {
          "expr": "go_memstats_heap_sys_bytes{namespace=\"$namespace\", job=~\".*headscale.*\"}",
          "legendFormat": "Heap Sys"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 32,
      "title": "Go Alloc Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(go_memstats_alloc_bytes_total{namespace=\"$namespace\", job=~\".*headscale.*\"}[5m])",
          "legendFormat": "Alloc Rate"
        },
        {
          "expr": "rate(go_memstats_mallocs_total{namespace=\"$namespace\", job=~\".*headscale.*\"}[5m])",
          "legendFormat": "Malloc Rate (obj/s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Malloc Rate (obj/s)" }, "properties": [{ "id": "unit", "value": "ops" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 40,
      "title": "Network I/O",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Network Receive",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"$namespace\", pod=~\"headscale.*\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }} RX"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 42,
      "title": "Network Transmit",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"$namespace\", pod=~\"headscale.*\"}[5m])) by (pod)",
          "legendFormat": "{{ pod }} TX"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 50,
      "title": "Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "id": 51,
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{namespace=\"$namespace\", app=~\"headscale.*\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 52,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 52 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{namespace=\"$namespace\", app=~\"headscale.*\"} |~ \"(?i)error|panic|fatal|fail\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
